# =============================================================================
# DevOpsGPT — example environment configuration
#
# Copy to `.env` and fill in. EVERYTHING here is optional: the app starts and
# runs in MOCK mode with zero configuration so you can demo offline. Add real
# credentials to switch individual integrations from mock -> live.
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
DEVOPSGPT_APP_NAME=DevOpsGPT
DEVOPSGPT_LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
DEVOPSGPT_LOG_JSON=false                 # true => JSON logs (prod), false => pretty (dev)
DEVOPSGPT_HOST=0.0.0.0
DEVOPSGPT_PORT=8000
DEVOPSGPT_CORS_ORIGINS=*                 # comma-separated origins, or * for all

# Global kill-switch for any state-changing action (create ticket / open PR).
# When false, the agent plans the action and returns the payload but does NOT
# call out to Jira/GitHub. Great for safe demos.
DEVOPSGPT_ALLOW_WRITE_ACTIONS=true

# Agent loop bounds.
DEVOPSGPT_MAX_AGENT_ITERATIONS=12
DEVOPSGPT_AGENT_TIMEOUT_S=120

# -----------------------------------------------------------------------------
# LLM provider — drives the agent's reasoning
#   claude        => Anthropic API (best tool-use / agentic behavior)
#   splunk-hosted => Splunk Hosted Models (gpt-oss-*), OpenAI-compatible
#   mock          => deterministic canned reasoning (offline demo, default)
# -----------------------------------------------------------------------------
DEVOPSGPT_LLM_PROVIDER=mock

# --- Claude (Anthropic) ---
ANTHROPIC_API_KEY=
DEVOPSGPT_CLAUDE_MODEL=claude-opus-4-8
DEVOPSGPT_CLAUDE_MAX_TOKENS=4096

# --- Splunk Hosted Models (OpenAI-compatible) ---
# Base URL is deployment-specific; leave unset to disable this provider.
# Expected pattern: <base>/v1/chat/completions
HOSTED_MODELS_BASE_URL=
HOSTED_MODELS_API_KEY=
HOSTED_MODELS_DEFAULT_MODEL=gpt-oss-20b      # gpt-oss-120b | gpt-oss-20b | Foundation-Sec-1.1-8B
HOSTED_MODELS_OPENAI_COMPAT=true

# -----------------------------------------------------------------------------
# Splunk connection
#   Mode selects the search backend. The "auto" mode prefers MCP and falls back
#   to REST automatically; if neither is reachable it uses bundled mock data.
#     auto | mcp | rest | mock
# -----------------------------------------------------------------------------
SPLUNK_MODE=auto

# --- Common Splunk credentials (shared by MCP env + REST) ---
SPLUNK_HOST=localhost
SPLUNK_MGMT_PORT=8089                    # management/REST port (NOT the 8000 web UI)
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=true                   # set false for self-signed lab certs
SPLUNK_AUTH_SCHEME=bearer                # bearer | splunk | basic
SPLUNK_TOKEN=                            # JWT or session key (for bearer/splunk)
SPLUNK_USERNAME=                         # basic-auth fallback only
SPLUNK_PASSWORD=

# --- Search behavior ---
SPLUNK_SEARCH_MODE=oneshot               # oneshot | export | async (oneshot avoids poll loop)
SPLUNK_REST_API_VERSION=v1               # v1 | v2 (v2 namespace only on newer Splunk)
SPLUNK_DEFAULT_EARLIEST=-24h
SPLUNK_DEFAULT_LATEST=now
SPLUNK_DEFAULT_INDEX=main

# --- Splunk MCP Server (Splunkbase app 8047) ---
# stdio launches the server as a subprocess; http/sse connects to a running one.
MCP_TRANSPORT=stdio                      # stdio | sse | http
MCP_SERVER_COMMAND=                      # e.g. "splunk-mcp-server" or "python"
MCP_SERVER_ARGS=                         # comma-separated args, e.g. "-m,splunk_mcp"
MCP_SERVER_URL=                          # for sse/http transport, e.g. http://localhost:8050/sse

# -----------------------------------------------------------------------------
# Action integrations — Jira & GitHub
#   Each has an explicit mode: mock | live. "live" requires creds below;
#   if creds are missing while mode=live, the adapter degrades to mock + warns.
# -----------------------------------------------------------------------------
# --- Jira ---
JIRA_MODE=mock                           # mock | live
JIRA_BASE_URL=                           # https://your-org.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=OPS
JIRA_DEFAULT_ISSUE_TYPE=Bug

# --- GitHub ---
GITHUB_MODE=mock                         # mock | live
GITHUB_TOKEN=                            # PAT with repo scope
GITHUB_REPO=                             # owner/repo, e.g. your-org/checkout-service
GITHUB_DEFAULT_BASE_BRANCH=main
GITHUB_API_URL=https://api.github.com
